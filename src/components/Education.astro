---
import LinkButton from "@/components/LinkButton.astro"

import GraduationCap from "@/components/icons/GraduationCap.astro"

const EDUCATION = [
    {
        title: "Grado en Ingeniería en Tecnologías de Telecomunicación",
        institution: "Universidad Carlos III de Madrid",
        grade: "7.0",
        period: "2018 – 2022",
        link: "https://www.uc3m.es/grado/telecomunicacion",
    },
]
---

<div class="flex flex-col gap-y-3">
    {
        EDUCATION.map(({ title, institution, grade, period, link }) => (
            <article class="flex items-start justify-between gap-4 pt-4">
                <div class="flex gap-3 items-start">
                    <div class="mt-0.5 p-2">
                        <GraduationCap class="size-4 text-[var(--color-subtle)]" />
                    </div>
                    <div>
                      <a href={link} target="_blank" rel="noopener noreferrer" class="group/link">
                          <h3 class="text-sm font-medium text-[var(--color-text)] group-hover/link:underline">
                              {title}
                          </h3>
                      </a>
                      <p class="text-xs text-[var(--color-subtle)]">{institution}</p>
                  </div>
                </div>

                <div class="flex flex-col items-end gap-1.5 shrink-0">
                    <span class="text-xs text-[var(--color-subtle)]">
                        {period}
                    </span>
                    <span class="text-xs text-[var(--color-subtle)]">
                        Nota: <span class="text-[var(--color-text)] font-medium">{grade}</span>
                    </span>
                </div>
            </article>
        ))
    }
</div>