---
interface Props {
    title: string;
    company: string;
    date: string;
    description: string;
}

const { title, company, date, description } = Astro.props;
---

<div class="relative pl-6 pb-10 before:absolute before:left-0 before:top-0 before:h-full before:w-px before:bg-[var(--color-border)]">
    <span class="absolute left-[-2px] top-1.5 w-[5px] h-[5px] rounded-full bg-[var(--color-subtle)]"></span>

    <div class="grid md:grid-cols-5 md:gap-10">
        <div class="md:col-span-2 mb-2 md:mb-0">
            <h3 class="text-base font-medium text-[var(--color-text)]">{title}</h3>
            <h4 class="text-sm text-[var(--color-subtle)]">{company}</h4>
            <time class="text-xs text-[color-mix(in srgb, var(--color-subtle) 70%, transparent)]">{date}</time>
        </div>

        <div class="flex flex-col gap-2 text-sm text-[var(--color-subtle)] md:col-span-3">
            {description}
        </div>
    </div>
</div>