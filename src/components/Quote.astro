---
interface Props {
    quote: string;
    author: string;
}

const { quote, author } = Astro.props;
---

<figure class="rounded-md bg-[var(--color-bg-pill)] px-6 py-5 w-full text-right">
    <blockquote>
        <p class="font-serif text-lg italic leading-relaxed text-[var(--color-text)] opacity-80">
            "{quote}"
        </p>
    </blockquote>
    <figcaption class="mt-3 text-xs tracking-widest uppercase text-[var(--color-text)] opacity-50">
        — {author}
    </figcaption>
</figure>